# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Ascii Box API key — REQUIRED for the adapter and every Box-backed test.
# Get one at https://box.ascii.dev
BOX_API_KEY=

# Anthropic credentials — required ONLY for the Claude-agent evals
# (sdks/harbor-box-evals). Not needed for the adapter self-test.
# Provide EITHER an API key OR a Claude subscription token (`claude setup-token`).
ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN=

# Optional: model alias for the eval agent (default: sonnet)
# HARBOR_BOX_EVAL_MODEL=sonnet
